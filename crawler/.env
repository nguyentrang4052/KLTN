DATABASE_URL=postgresql://postgres:123456@localhost:5432/RecruitmentDB
REDIS_URL=redis://localhost:6379

MAX_PAGES_PER_CATEGORY=0
MAX_CONCURRENT_JOBS=3
SAVE_TO_DB=true
USE_REDIS_CACHE=false
CRAWL_INTERVAL_MINUTES=2


PLATFORM_TIMEOUT=1000
MAX_JOBS_PER_SESSION=1000
CONTINUOUS_MODE=true

RESET_ISNEWJOB_AFTER_HOURS=48      # Reset isNewJob sau 2 ngày (48 giờ)
MAINTENANCE_INTERVAL_HOURS=6       # Chạy maintenance mỗi 6 giờ

# Optional: Cleanup tracking records
CLEANUP_TRACKING_AFTER_DAYS=30     # Xóa tracking cũ sau 30 ngày