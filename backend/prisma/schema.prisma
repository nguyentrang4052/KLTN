generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  accountID Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  provider  String
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
  user      User?
  role      String   @default("user")
  jobAlerts JobAlert[]
  emailNotification Boolean @default(false)
  searchHistory SearchHistory[]
}

model User {
  userID             Int                 @id @default(autoincrement())
  fullName           String?
  birthYear          Int?
  phone              String?
  gender             String?
  address            String?
  accountID          Int                 @unique
  avatar             String?
  jobRecommendations JobRecommendation[]
  savedJobs          SavedJob[]
  account            Account             @relation(fields: [accountID], references: [accountID])
  behaviors          UserBehavior[]
  profiles           UserProfile?
  skills             UserSkill[]
  subscriptions UserSubscription[]
  payments      Payment[]
  quotas UserQuota[]
  refundRequests RefundRequest[]
  notifications Notification[]
  cvAnalyses   CVAnalysis[] 
  cvAnalysisCaches CVAnalysisCache[]
  chatSession ChatSession[]
  cvBuilder CVBuilder[]
}

model UserProfile {
  id             Int       @id @default(autoincrement())
  jobTitle       String?
  experienceYear String?
  careerLevel    String?
  expectedSalary String?
  workingType    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userID     Int   @unique
  user       User      @relation(fields: [userID], references: [userID])
  industryID Int?
  industry   Industry? @relation(fields: [industryID], references: [id])
}

model UserSkill {
  id      Int   @id @default(autoincrement())
  userID  Int
  skillID Int
  skill   Skill @relation(fields: [skillID], references: [skillID])
  user    User  @relation(fields: [userID], references: [userID])
}


model Company {
  companyID      Int     @id @default(autoincrement())
  companyName    String  @unique
  companyWebsite String?
  companyProfile String?
  address        String?
  companySize    String?
  companyLogo    String?
  jobs           Job[]
}

model Job {
  jobID           Int                 @id @default(autoincrement())
  companyID       Int
  industryID      Int?
  title           String?
  location        String?
  salary          String?
  description     String?
  requirement     String?
  benefit         String?
  jobType         String?
  workingTime     String?
  experienceYear  String?
  postedAt        DateTime?
  deadline        DateTime?
  sourcePlatform  String?
  sourceLink      String?             @unique
  isActive        Boolean             @default(true)
  other           String?
  shortLocation   String?
  isNewJob        Boolean             @default(false)
  discoveredAt    DateTime?
  company         Company             @relation(fields: [companyID], references: [companyID])
  industry        Industry?           @relation(fields: [industryID], references: [id])
  recommendations JobRecommendation[]
  skills          JobSkill[]
  sourceTrackings JobSourceTracking[]
  savedJobs       SavedJob[]
  behaviors       UserBehavior[]
}

model JobRecommendation {
  id           Int      @id @default(autoincrement())
  userID       Int
  jobID        Int
  matchPercent Float
  reason       String? 
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  job          Job      @relation(fields: [jobID], references: [jobID])
  user         User     @relation(fields: [userID], references: [userID])

  @@unique([userID, jobID])
}

model JobSkill {
  id      Int   @id @default(autoincrement())
  jobID   Int
  skillID Int
  job     Job   @relation(fields: [jobID], references: [jobID])
  skill   Skill @relation(fields: [skillID], references: [skillID])
}

model SavedJob {
  id      Int      @id @default(autoincrement())
  userID  Int
  jobID   Int
  savedAt DateTime @default(now())

  user User @relation(fields: [userID], references: [userID])
  job  Job  @relation(fields: [jobID], references: [jobID])

  @@unique([userID, jobID])
}

model Industry {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  jobs         Job[]
  skills       Skill[]
  userProfiles UserProfile[]
}

model Skill {
  skillID    Int         @id @default(autoincrement())
  industryID Int
  name       String      
  jobs       JobSkill[]
  industry   Industry    @relation(fields: [industryID], references: [id])
  users      UserSkill[]

  @@unique([name, industryID])
}

model UserBehavior {
  id        Int      @id @default(autoincrement())
  userID    Int
  jobID     Int
  action    String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobID], references: [jobID])
  user      User     @relation(fields: [userID], references: [userID])
}


model JobSourceTracking {
  id            Int      @id @default(autoincrement())
  jobID         Int
  platform      String
  externalJobID String
  crawledAt     DateTime @default(now())
  job           Job      @relation(fields: [jobID], references: [jobID])
}

model SubscriptionPlan {
  id           Int      @id @default(autoincrement())
  name         String   @unique  
  displayName  String
  monthlyPrice Int      @default(0)
  yearlyPrice  Int      @default(0)
  createdAt    DateTime @default(now())
  subscriptions UserSubscription[]
  limits        PlanLimit?
}

model PlanLimit {
  id                  Int    @id @default(autoincrement())
  planID              Int    @unique
  jobSuggestPerDay    Int    @default(3)    
  cvAnalysisPerMonth  Int    @default(0)  
  cvMatchCheckCount   Int    @default(0) 
  plan                SubscriptionPlan @relation(fields: [planID], references: [id])
}

model UserSubscription {
  id         Int      @id @default(autoincrement())
  userID     Int
  planID     Int
  billing    String
  status     String
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  autoRenew  Boolean  @default(true)
  user       User     @relation(fields: [userID], references: [userID])
  plan       SubscriptionPlan @relation(fields: [planID], references: [id])
  payments   Payment[]
  quota UserQuota?
}

model Payment {
  id             Int      @id @default(autoincrement())
  userID         Int
  subscriptionID Int
  amount         Int
  currency       String   @default("VND")
  status         String
  method         String?
  transactionRef String?  @unique
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userID], references: [userID])
  subscription   UserSubscription @relation(fields: [subscriptionID], references: [id])
  refundRequest  RefundRequest?
}


model UserQuota {
  id                  Int      @id @default(autoincrement())
  userID              Int
  subscriptionID      Int?     @unique  
  month               String         

  jobSuggestPerDay    Int      @default(3)
  jobSuggestUsedToday Int      @default(0)
  jobSuggestResetDate String?

  cvAnalysisTotal     Int      @default(0)
  cvMatchCheckTotal   Int      @default(0)
  cvAnalysisUsed      Int      @default(0)
  cvMatchCheckUsed    Int      @default(0)

  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userID], references: [userID])
  subscription        UserSubscription? @relation(fields: [subscriptionID], references: [id])

  @@unique([userID, month])
}

model RefundRequest {
  id            Int      @id @default(autoincrement())
  userID        Int
  paymentID     Int      @unique
  reason        String
  accountNumber String
  accountName   String
  bankName      String
  status        String   @default("pending") // pending | approved | rejected
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
  note          String?  

  user    User    @relation(fields: [userID], references: [userID])
  payment Payment @relation(fields: [paymentID], references: [id])
}


model CVAnalysis {
  id         Int      @id @default(autoincrement())
  userID     Int
  fileHash   String   @unique // SHA256 hash để kiểm tra trùng file
  filename   String
  result     Json     // Lưu toàn bộ kết quả phân tích JSON
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  user       User     @relation(fields: [userID], references: [userID], onDelete: Cascade)
  
  @@index([userID])
  @@index([fileHash])
  @@index([createdAt])
}


model CVAnalysisCache {
  id         Int      @id @default(autoincrement())
  userID     Int
  fileHash   String   @unique
  filename   String
  result     Json     
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  
  user       User     @relation(fields: [userID], references: [userID], onDelete: Cascade)
  
  @@index([userID])
  @@index([fileHash])
}

model ChatSession {
  id        Int @id @default(autoincrement())
  userID    Int
  title     String @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isPinned  Boolean         @default(false)
  user      User     @relation(fields: [userID], references: [userID], onDelete: Cascade)
  messages  ChatMessage[]
}

model ChatMessage {
  id        Int @id @default(autoincrement())
  sessionID Int
  role      String
  content   String?
  type      String @default("text")
  metadata  Json?
  createdAt DateTime @default(now())
  session   ChatSession @relation(fields: [sessionID], references: [id], onDelete: Cascade)

  @@index([sessionID])
  @@index([createdAt])
  @@index([sessionID, createdAt])
} 

model CVBuilder {
  id         Int      @id @default(autoincrement())
  userID     Int
  name       String
  templateId String   
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userID], references: [userID], onDelete: Cascade)

  @@index([userID])
}

model JobAlert {
  id        Int      @id @default(autoincrement())
  accountID Int
  keyword   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountID], references: [accountID])

  @@unique([accountID, keyword])
}

model Notification {
  id        Int       @id @default(autoincrement())
  userID    Int
  type      String    // 'subscription_expiry' | 'job_deadline' | 'job_alert' | 'payment_success'
  title     String
  body      String
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?
  metadata  Json?    

  user User @relation(fields: [userID], references: [userID])
  dedupeKey String?   @unique
  deletedAt DateTime?
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  accountID Int
  keyword   String
  type      String   @default("job") // "job" | "company"
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountID], references: [accountID])

  @@index([accountID])
}