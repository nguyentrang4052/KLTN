generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  accountID Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  provider  String
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
  user      User?
  role      String   @default("user")
}

model User {
  userID             Int                 @id @default(autoincrement())
  fullName           String?
  birthYear          Int?
  phone              String?
  gender             String?
  address            String?
  accountID          Int                 @unique
  avatar             String?
  applications       ApplyHistory[]
  cvs                CV[]
  jobRecommendations JobRecommendation[]
  savedJobs          SavedJob[]
  account            Account             @relation(fields: [accountID], references: [accountID])
  behaviors          UserBehavior[]
  profiles           UserProfile[]
  skills             UserSkill[]
  subscriptions UserSubscription[]
  payments      Payment[]
  quotas UserQuota[]
  refundRequests RefundRequest[]
}

model UserProfile {
  id             Int       @id @default(autoincrement())
  jobTitle       String?
  experienceYear String?
  careerLevel    String?
  expectedSalary String?
  workingType    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userID     Int
  user       User      @relation(fields: [userID], references: [userID])
  industryID Int?
  industry   Industry? @relation(fields: [industryID], references: [id])
}

model UserSkill {
  id      Int   @id @default(autoincrement())
  userID  Int
  skillID Int
  skill   Skill @relation(fields: [skillID], references: [skillID])
  user    User  @relation(fields: [userID], references: [userID])
}

model CV {
  id           Int            @id @default(autoincrement())
  userID       Int
  title        String
  applications ApplyHistory[]
  user         User           @relation(fields: [userID], references: [userID])
}

model Company {
  companyID      Int     @id @default(autoincrement())
  companyName    String  @unique
  companyWebsite String?
  companyProfile String?
  address        String?
  companySize    String?
  companyLogo    String?
  jobs           Job[]
}

model Job {
  jobID           Int                 @id @default(autoincrement())
  companyID       Int
  industryID      Int?
  title           String?
  location        String?
  salary          String?
  description     String?
  requirement     String?
  benefit         String?
  jobType         String?
  workingTime     String?
  experienceYear  String?
  postedAt        DateTime?
  deadline        DateTime?
  sourcePlatform  String?
  sourceLink      String?             @unique
  isActive        Boolean             @default(true)
  other           String?
  shortLocation   String?
  isNewJob        Boolean             @default(false)
  discoveredAt    DateTime?
  applyHistories  ApplyHistory[]
  company         Company             @relation(fields: [companyID], references: [companyID])
  industry        Industry?           @relation(fields: [industryID], references: [id])
  recommendations JobRecommendation[]
  skills          JobSkill[]
  sourceTrackings JobSourceTracking[]
  savedJobs       SavedJob[]
  behaviors       UserBehavior[]
}

model JobRecommendation {
  id           Int      @id @default(autoincrement())
  userID       Int
  jobID        Int
  matchPercent Float
  createdAt    DateTime @default(now())
  job          Job      @relation(fields: [jobID], references: [jobID])
  user         User     @relation(fields: [userID], references: [userID])

  @@unique([userID, jobID])
}

model JobSkill {
  id      Int   @id @default(autoincrement())
  jobID   Int
  skillID Int
  job     Job   @relation(fields: [jobID], references: [jobID])
  skill   Skill @relation(fields: [skillID], references: [skillID])
}

model SavedJob {
  id      Int      @id @default(autoincrement())
  userID  Int
  jobID   Int
  savedAt DateTime @default(now())

  user User @relation(fields: [userID], references: [userID])
  job  Job  @relation(fields: [jobID], references: [jobID])

  @@unique([userID, jobID])
}

model Industry {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  jobs         Job[]
  skills       Skill[]
  userProfiles UserProfile[]
}

model Skill {
  skillID    Int         @id @default(autoincrement())
  industryID Int
  name       String      
  jobs       JobSkill[]
  industry   Industry    @relation(fields: [industryID], references: [id])
  users      UserSkill[]

  @@unique([name, industryID])
}

model UserBehavior {
  id        Int      @id @default(autoincrement())
  userID    Int
  jobID     Int
  action    String
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobID], references: [jobID])
  user      User     @relation(fields: [userID], references: [userID])
}

model ApplyHistory {
  id        Int      @id @default(autoincrement())
  userID    Int
  jobID     Int
  cvID      Int
  status    String
  appliedAt DateTime @default(now())
  cv        CV       @relation(fields: [cvID], references: [id])
  job       Job      @relation(fields: [jobID], references: [jobID])
  user      User     @relation(fields: [userID], references: [userID])
}

model JobSourceTracking {
  id            Int      @id @default(autoincrement())
  jobID         Int
  platform      String
  externalJobID String
  crawledAt     DateTime @default(now())
  job           Job      @relation(fields: [jobID], references: [jobID])
}

model SubscriptionPlan {
  id           Int      @id @default(autoincrement())
  name         String   @unique  
  displayName  String
  monthlyPrice Int      @default(0)
  yearlyPrice  Int      @default(0)
  createdAt    DateTime @default(now())
  subscriptions UserSubscription[]
  limits        PlanLimit?
}

model PlanLimit {
  id                  Int    @id @default(autoincrement())
  planID              Int    @unique
  jobSuggestPerDay    Int    @default(3)    
  cvAnalysisPerMonth  Int    @default(0)  
  cvMatchCheckCount   Int    @default(0) 
  plan                SubscriptionPlan @relation(fields: [planID], references: [id])
}

model UserSubscription {
  id         Int      @id @default(autoincrement())
  userID     Int
  planID     Int
  billing    String
  status     String
  startedAt  DateTime @default(now())
  expiresAt  DateTime
  autoRenew  Boolean  @default(true)
  user       User     @relation(fields: [userID], references: [userID])
  plan       SubscriptionPlan @relation(fields: [planID], references: [id])
  payments   Payment[]
}

model Payment {
  id             Int      @id @default(autoincrement())
  userID         Int
  subscriptionID Int
  amount         Int
  currency       String   @default("VND")
  status         String
  method         String?
  transactionRef String?  @unique
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userID], references: [userID])
  subscription   UserSubscription @relation(fields: [subscriptionID], references: [id])
  refundRequest  RefundRequest?
}


model UserQuota {
  id                  Int      @id @default(autoincrement())
  userID              Int
  month               String  
  
  jobSuggestPerDay    Int      @default(3)   
  cvAnalysisTotal     Int      @default(0)   
  cvMatchCheckTotal   Int      @default(0)  
  
  cvAnalysisUsed      Int      @default(0)
  cvMatchCheckUsed    Int      @default(0)

  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userID], references: [userID])

  @@unique([userID, month])
}

model RefundRequest {
  id            Int      @id @default(autoincrement())
  userID        Int
  paymentID     Int      @unique
  reason        String
  accountNumber String
  accountName   String
  bankName      String
  status        String   @default("pending") // pending | approved | rejected
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?
  note          String?  

  user    User    @relation(fields: [userID], references: [userID])
  payment Payment @relation(fields: [paymentID], references: [id])
}